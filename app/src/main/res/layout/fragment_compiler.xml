<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Status NDK + Tombol Install -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvNdkStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="❌ NDK Belum Terinstall"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnInstallNdk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Install NDK"
            android:textSize="12sp"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Editor Kode -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kode C++:"
        android:textStyle="bold"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etCode"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top|start"
        android:hint="#include <cstdio>\n\nextern \"C\" int add(int a, int b) {\n    return a + b;\n}"
        android:inputType="textMultiLine|textNoSuggestions"
        android:typeface="monospace"
        android:textSize="12sp"
        android:scrollbars="vertical"
        android:background="#F5F5F5"
        android:padding="8dp" />

    <!-- Tombol Compile & Save -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnCompile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ Compile"
            android:enabled="false" />

        <Button
            android:id="@+id/btnSaveSo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💾 Simpan .so" />
    </LinearLayout>

    <!-- Log Output -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log:"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#1E1E1E"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log akan muncul di sini..."
            android:textColor="#FFFFFF"
            android:typeface="monospace"
            android:textSize="11sp" />
    </ScrollView>

</LinearLayout>